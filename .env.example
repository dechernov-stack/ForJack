# ============================================================================
# storytelling-bot · переменные окружения
# Скопируйте в .env (не коммитить — он в .gitignore) и заполните своими ключами.
# ============================================================================

# --- LLM (выберите одного провайдера для дефолтного раннтайма) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1

# --- Search & news ---
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=
# GDELT — публичный, ключ не нужен
# NEWSAPI_KEY=

# --- Crunchbase / LinkedIn (опционально, платные) ---
# CRUNCHBASE_API_KEY=
# LINKEDIN_API_KEY=

# --- Storage (для production; локально — sqlite + filesystem) ---
DATABASE_URL=postgresql+psycopg://storyteller:storyteller@localhost:5432/storyteller
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=storytelling-bronze
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=storyteller

# --- Observability ---
# Keys MUST use the exact pk-lf-... / sk-lf-... prefixes from Langfuse UI.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# HOST variants (pick one):
#   Mac CLI (local)  → http://localhost:3000
#   Inside Docker    → http://langfuse:3000
#   VPS CLI          → http://localhost:3000  (Langfuse runs on same host)
#   Cloud Langfuse   → https://cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000

# --- Alerting ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Сервис ---
LOG_LEVEL=INFO
WATCHLIST_PATH=./data/watchlist.json

# --- Планировщик (systemd timer, через пробел) ---
WATCHLIST_ENTITIES="stripe anthropic"
