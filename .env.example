# ============================================================================
# storytelling-bot · переменные окружения
# Скопируйте в .env (не коммитить — он в .gitignore) и заполните своими ключами.
# ============================================================================

# --- LLM (выберите одного провайдера для дефолтного раннтайма) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1

# --- Search & news ---
TAVILY_API_KEY=tvly-...
BRAVE_API_KEY=
# GDELT — публичный, ключ не нужен
# NEWSAPI_KEY=

# --- Crunchbase / LinkedIn (опционально, платные) ---
# CRUNCHBASE_API_KEY=
# LINKEDIN_API_KEY=

# --- Storage (для production; локально — sqlite + filesystem) ---
DATABASE_URL=postgresql+psycopg://storyteller:storyteller@localhost:5432/storyteller
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=storytelling-bronze
QDRANT_URL=http://localhost:6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=storyteller

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Alerting ---
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Сервис ---
LOG_LEVEL=INFO
WATCHLIST_PATH=./data/watchlist.json
